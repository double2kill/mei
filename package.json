{
  "name": "mei",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run dev:web",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:all": "pnpm --parallel --filter web --filter api dev",
    "build": "pnpm run build:web",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter api build",
    "build:all": "pnpm run build:web && pnpm run build:api",
    "start:web": "pnpm --filter web start",
    "start:api": "pnpm --filter api start",
    "lint": "pnpm --filter web exec tsc --noEmit",
    "deploy": "pnpm --filter web deploy && pnpm --filter api deploy",
    "deploy:web": "pnpm --filter web deploy",
    "deploy:api": "pnpm --filter api deploy"
  }
}
